# Frontend/API base URL (used by docusaurus.config.js customFields.apiBaseUrl)
# Must point to the local API server (server.js), NOT the Docusaurus port
REACT_APP_API_BASE_URL=http://localhost:3001

# GitHub OAuth app credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# JWT signing secret for CIROH Hub auth sessions
JWT_SECRET=

# Repository where admin submissions create issues
GITHUB_REPO=CIROH-UA/ciroh_hub

# OAuth scope and token lifetime
GITHUB_OAUTH_SCOPE=public_repo read:user
JWT_EXPIRES_IN=7d

# Runtime URL settings for callback redirect
# API_BASE_URL: the Express server origin (used to build the OAuth callback URL)
# FRONTEND_URL: the Docusaurus dev server origin (where the user's browser is)
API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
FRONTEND_BASE_PATH=/local
FRONTEND_URLS=http://localhost:3000

# Optional labels for created issues
PRODUCT_ISSUE_LABEL=enhancement
BLOG_ISSUE_LABEL=blog
